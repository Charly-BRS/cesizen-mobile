# .env.example
# Copier ce fichier en .env et remplir les valeurs
# Les variables EXPO_PUBLIC_ sont exposées côté client (ne pas y mettre de secrets)

# URL de base de l'API Symfony
# En développement local, utiliser l'IP de la machine (pas localhost depuis le téléphone)
# Exemple avec IP locale : EXPO_PUBLIC_API_URL=http://192.168.1.100:8080/api/v1
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
